# User data (external, never committed) — cache/logs/config live beside the app
# in portable mode. The vault/ is committed (it IS the tracked knowledge base).
/cache/
/logs/
/config/
app/cache.sqlite
**/cache.sqlite
**/__pycache__/
*.pyc

# Python envs / test cache
.venv/
venv/
env/
.pytest_cache/
**/.pytest_cache/

# Obsidian workspace UI state (keep vault content, drop per-session churn)
**/.obsidian/workspace*.json
**/.obsidian/cache
.obsidian/
vault/.trash/

# PyInstaller desktop build output (rebuildable — never commit the binary)
dist/
build/
*.spec

# OS
.DS_Store
Thumbs.db
