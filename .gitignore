# App cache — disposable, rebuilt from the vault (ADR-001)
app/cache.sqlite
**/__pycache__/
*.pyc

# Python envs / test cache
.venv/
venv/
env/
.pytest_cache/
**/.pytest_cache/

# Obsidian workspace UI state (keep vault content, drop per-session churn)
**/.obsidian/workspace*.json
**/.obsidian/cache
.obsidian/
vault/.trash/

# PyInstaller desktop build output (rebuildable — never commit the binary)
dist/
build/
*.spec

# OS
.DS_Store
Thumbs.db
